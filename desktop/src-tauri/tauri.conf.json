{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CheatSheetMaker",
  "version": "0.1.0",
  "identifier": "com.cheatsheetmaker.app",
  "build": {
    "frontendDist": "dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "CheatSheetMaker",
        "url": "loading.html",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/cheatsheetmaker-backend",
      "binaries/node-server"
    ],
    "resources": [
      "resources/frontend/**/*"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
