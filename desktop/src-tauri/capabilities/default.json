{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/cheatsheetmaker-backend", "sidecar": true },
        { "name": "binaries/node-server", "sidecar": true }
      ]
    }
  ]
}
