# ============================================================
# CheatSheetMaker — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ============================================================

# --- Instance name — used as prefix for Docker container names ---
# Must be unique per instance on the same machine (e.g. myproject, work, personal)
INSTANCE_NAME=cheatsheetmaker

# --- Ports — change if you run multiple instances on the same machine ---
DB_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- PostgreSQL (used by docker-compose and backend) ---
POSTGRES_USER=cheatsheetmaker
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=cheatsheetmakerdb

# --- Backend ---
# Full PostgreSQL URL (used directly by the FastAPI app)
# Inside Docker Compose the host is always "db" (the service name)
# For local dev with start.ps1 use "localhost" instead
DATABASE_URL=postgresql://cheatsheetmaker:change_me_strong_password@localhost:5432/cheatsheetmakerdb

# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=change_me_run_openssl_rand_hex_32

# Token expiry (optional, defaults shown)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# --- Frontend (only needed outside Docker) ---
BACKEND_URL=http://localhost:8000
